# Google Cloud / Gemini
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=europe-west9
GOOGLE_GENAI_USE_VERTEXAI=true
# ou, à la place, une clé API :
# GOOGLE_API_KEY=your-api-key

# Chemin vers un service-account JSON (hors Git)
GOOGLE_APPLICATION_CREDENTIALS=./credentials.local.json

# Model IDs
# confirm exact Gemini model IDs and europe-west9 availability at the wiring phase
EXTRACTOR_MODEL=gemini-x.x-multimodal-placeholder
WRITER_MODEL=gemini-x.x-reasoning-placeholder
# optional; used only when the primary model returns sustained 503
FALLBACK_MODEL=gemini-x.x-fallback-placeholder

# Config app
ALLOWED_EMAILS=sacristine@example.com,pere.bernard@example.com
# Fallback recipient — the sacristan's own mailbox; drafts are addressed
# to her when the notes contain no email, so the deliverable always exists
# and she fills real recipients at send time.
SACRISTAN_EMAIL=sacristine@example.com
SHEET_ID=your-google-sheet-id

# Google Drive — the déroulé .docx is uploaded as a native Google Doc
# using the sacristan's own OAuth credentials (same grant as Gmail).
# Requirements:
#   1. Enable the Google Drive API in the Cloud Console.
#   2. drive.file scope is included in the OAuth consent (added to
#      agents/auth.py SCOPES).  Delete token.local.json and re-run
#      `python agents/auth.py` once to re-consent.
#   3. The Doc lives IN the sacristan's Drive — she owns it, no
#      sharing step needed.  Service accounts have no Drive storage.

# Application-level Google Sign-In (network-open, application-gated)
# AUTH_MODE: "on" (cloud default) = require login; "off" = local dev
AUTH_MODE=off
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# Comma-separated list of Google accounts allowed to use the app
AUTH_ALLOWED_EMAILS=sacristine@example.com
# Session cookie signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-generate-with-secrets-token-hex-32
# Set to true when running behind HTTPS (Cloud Run)
AUTH_HTTPS_ONLY=false

# Langfuse Observability
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json
