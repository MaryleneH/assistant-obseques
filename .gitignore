# Secrets & credentials — NEVER commit
.env
.env.*
!.env.example
*.key
*.pem
service-account*.json
credentials*.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/

# Node / frontend (A2UI screen, docx skill)
node_modules/
dist/

# OS / Editor
.DS_Store
.idea/

# Real data — never in Git (fictional test data lives in examples/)
data/
*.local.*

# Antigravity local tool state — never versioned.
# Antigravity 2.0 centralizes configuration in the user's home (~/.gemini);
# any .antigravity*/ folder appearing in the workspace is a machine-local
# cache (legacy 1.x / CLI), not source code. Excluded to keep the repo
# clean and reproducible for anyone cloning it.
.antigravity/
.antigravitycli/
output/
